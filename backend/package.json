{
  "name": "netwatch-backend",
  "version": "1.1.0",
  "description": "NetWatch Monitoring Platform Backend API - 支持WebSocket实时通信和JWT认证",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:ws": "node src/server-websocket.js",
    "start:lite": "node src/server-json.js",
    "dev": "node --watch src/server.js",
    "dev:ws": "node --watch src/server-websocket.js",
    "dev:lite": "node --watch src/server-json.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:seed:lite": "node src/config/database-json.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  }
}
